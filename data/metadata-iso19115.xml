            <gco:CharacterString>NRCS Regenerative Agriculture Risk Map — Fragile Soil Index and Organic Matter Depletion, National SSURGO</gco:CharacterString>
          </title>
          <date>
            <CI_Date>
              <date><gco:Date>2026-06-01</gco:Date></date>
              <dateType>
